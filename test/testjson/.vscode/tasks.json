{
    "tasks": [
        {
            "label": "Build and Run C++",
            "type": "shell",
            "command": "/opt/rh/devtoolset-11/root/usr/bin/g++",
            "args": [
                "-std=c++17",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "&&",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "编译并运行当前C++文件"
        }
    ],
    "version": "2.0.0"
}